generator client {
  provider = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  extensions = [vector]
}

model Document {
  id        Int                 @id @default(autoincrement())
  content   String
  metadata  Json?
  embedding Unsupported("vector(1536)")?

  @@map("documents")
}
